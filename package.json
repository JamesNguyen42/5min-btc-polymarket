{
  "name": "kalshi-btc-updown",
  "version": "1.0.0",
  "private": true,
  "dependencies": {
    "@polymarket/clob-client-v2": "^1.0.8",
    "viem": "^2.33.3"
  },
  "overrides": {
    "ws": "^8.21.0"
  },
  "scripts": {
    "build": "node scripts/write_runtime_config.js",
    "dev": "node server.js",
    "start": "node server.js",
    "test": "node --test",
    "paper:any:once": "node scripts/kalshi_any_market_paper.mjs --once",
    "paper:any:12h": "node scripts/kalshi_any_market_paper.mjs --duration-hours 12 --starting-cash 8",
    "paper:any:12h:bg": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/start_kalshi_paper_12h.ps1",
    "paper:any:status": "node scripts/kalshi_any_market_paper.mjs --status",
    "paper:any:stop": "node scripts/kalshi_any_market_paper.mjs --stop",
    "suggestion:publish": "node scripts/trade_suggestion_cli.mjs publish",
    "suggestion:status": "node scripts/trade_suggestion_cli.mjs status",
    "suggestion:clear": "node scripts/trade_suggestion_cli.mjs clear",
    "advisory:12h": "node scripts/codex_advisory_loop.mjs run --duration-hours 12 --interval-minutes 20",
    "advisory:status": "node scripts/codex_advisory_loop.mjs status",
    "advisory:stop": "node scripts/codex_advisory_loop.mjs stop",
    "sim": "python scripts/simulate_btc_5m_virtual.py --days 7 --interval-minutes 15 --profile conservative --out runtime/kalshi_btc15m_virtual_backtest.json --csv runtime/kalshi_btc15m_virtual_backtest.csv",
    "sim:compare": "python scripts/simulate_btc_5m_virtual.py --days 7 --interval-minutes 15 --profile conservative --compare --out runtime/kalshi_btc15m_v1_v2_v3_compare.json --csv runtime/kalshi_btc15m_v1_v2_v3_compare.csv",
    "sim:live": "python scripts/simulate_btc_5m_virtual.py --live --compare --interval-minutes 15 --profile conservative"
  }
}
