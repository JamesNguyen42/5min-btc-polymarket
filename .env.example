# Local-only API credentials and API routing. Copy this file to .env and fill
# values there. Never commit .env.

# Llama/Nemotron hosted model API. Generate a developer key at build.nvidia.com.
# Hosted free endpoints are intended for prototyping and may be rate limited;
# they are not a guaranteed free 24/7 production service.
LLAMA_API_KEY=
NVIDIA_NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_LLAMA_MODEL=meta/llama-3.3-70b-instruct
NVIDIA_NEMOTRON_MODEL=nvidia/llama-3.3-nemotron-super-49b-v1.5

# Optional comma-separated RSS/Atom sources used as untrusted, read-only market
# context. Defaults to CoinDesk RSS plus a recent Bitcoin Google News feed.
# AI_NEWS_FEEDS=https://www.coindesk.com/arc/outboundfeeds/rss/,https://news.google.com/rss/search?q=Bitcoin+when:2h&hl=en-US&gl=US&ceid=US:en

# Kalshi API.
KALSHI_ENV=demo
# KALSHI_API_BASE_URL=
KALSHI_API_KEY_ID=

# Option A: paste the PEM private key with escaped newlines.
# Example shape:
# KALSHI_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
#
# If Kalshi gave you only the base64 key body without BEGIN/END lines, that is
# also accepted:
# KALSHI_PRIVATE_KEY=MIIE...
KALSHI_PRIVATE_KEY=

# Option B: store the PEM private key in a local file and point to it.
# KALSHI_PRIVATE_KEY_PATH=./secrets/kalshi.key
# KALSHI_PRIVATE_KEY_BASE64=

# Frontend-to-API routing / API CORS. FRONTEND_ORIGIN accepts a comma-separated
# list when both Vercel production and preview origins need access.
FRONTEND_ORIGIN=http://127.0.0.1:3000
SIM_API_BASE_URL=

# Polymarket APIs.
POLYMARKET_GAMMA_BASE_URL=https://gamma-api.polymarket.com
POLYMARKET_CLOB_BASE_URL=https://clob.polymarket.com

# Required for Polymarket account balance reads and live trading.
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_FUNDER_ADDRESS=

# Aliases accepted by this app if your host uses shorter names:
# PM_PRIVATE_KEY=
# PM_API=
# PM_API_SECRET_KEY=
# PM_API_PASSPHRASE=
# PM_FUNDER_ADDRESS=
# PM_SIGNATURE_TYPE=3

# New Polymarket API users normally use deposit wallets: signature type 3 plus
# funder address. Use 0 only if you intentionally trade from a standalone EOA
# wallet.
POLYMARKET_SIGNATURE_TYPE=3
POLYMARKET_CHAIN_ID=137
