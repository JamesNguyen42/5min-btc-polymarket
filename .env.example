# Local-only Kalshi credentials. Copy this file to .env and fill values there.
# Never commit .env.

# Use demo until you intentionally switch to production.
KALSHI_ENV=demo

# Your Kalshi API key ID.
KALSHI_API_KEY_ID=

# Option A: paste the PEM private key with escaped newlines.
# Example shape:
# KALSHI_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
#
# If Kalshi gave you only the base64 key body without BEGIN/END lines, that is
# also accepted:
# KALSHI_PRIVATE_KEY=MIIE...
KALSHI_PRIVATE_KEY=

# Option B: store the PEM private key in a local file and point to it.
# KALSHI_PRIVATE_KEY_PATH=./secrets/kalshi.key

# Render/Vercel split deploy.
FRONTEND_ORIGIN=http://127.0.0.1:3000
SIM_API_BASE_URL=

# Optional local override. Render uses /var/data/trading_state.json from render.yaml.
# TRADING_STATE_FILE=runtime/trading_state.json

# Trading page defaults.
TRADING_PRIMARY_STRATEGY=v1
PAPER_STARTING_CASH=10
LIVE_COMPARE_STRATEGIES=v1,v3
LIVE_COMPARE_STARTING_CASH=10
KALSHI_ENTRY_SECONDS_LEFT=180
KALSHI_MIN_SECONDS_LEFT=60
KALSHI_LIVE_MAX_PRICE_SLIPPAGE=0.03
KALSHI_LIVE_MAX_TAKE_PRICE=0.99
KALSHI_TAKER_FEE_RATE=0.07
KALSHI_LIVE_CASH_BUFFER_USD=0.25
KALSHI_ORDERBOOK_DEPTH=100
KALSHI_LIVE_TIME_IN_FORCE=immediate_or_cancel
# Fill-or-kill is disabled unless this is set to 1, even if the line above is fill_or_kill.
KALSHI_LIVE_ALLOW_FILL_OR_KILL=0

# Shared Kalshi public-market cache to avoid duplicate polling from workers.
KALSHI_MARKET_CACHE_MS=12000
KALSHI_SETTLEMENT_CACHE_MS=30000

# Polymarket BTC 5-minute worker defaults.
POLYMARKET_PRIMARY_STRATEGY=v1
POLYMARKET_COMPARE_STRATEGIES=v1
POLYMARKET_STARTING_CASH=10
POLYMARKET_BTC5M_SLUG_PREFIX=btc-updown-5m
POLYMARKET_POLL_MS=10000
POLYMARKET_ENTRY_SECONDS_LEFT=180
POLYMARKET_MIN_SECONDS_LEFT=10
POLYMARKET_TRIGGER_PRICE=0.70
POLYMARKET_MARKET_CACHE_MS=3000
POLYMARKET_SETTLEMENT_CACHE_MS=30000

# Required for Polymarket account balance reads and when you click
# "Start Polymarket live trading".
POLYMARKET_PRIVATE_KEY=
POLYMARKET_API_KEY=
POLYMARKET_API_SECRET=
POLYMARKET_API_PASSPHRASE=
POLYMARKET_FUNDER_ADDRESS=

# Aliases accepted by this app if your host uses shorter names:
# PM_PRIVATE_KEY=
# PM_API=
# PM_API_SECRET_KEY=
# PM_API_PASSPHRASE=
# PM_FUNDER_ADDRESS=
# PM_SIGNATURE_TYPE=3
# New Polymarket API users normally use deposit wallets: signature type 3 plus funder address.
# Use 0 only if you intentionally trade from a standalone EOA wallet.
# The dashboard's Account balance is spendable CLOB collateral, with an
# on-chain pUSD fallback for this funder. Allowance is approval, not cash.
POLYMARKET_SIGNATURE_TYPE=3
POLYMARKET_CHAIN_ID=137
POLYMARKET_LIVE_MAX_PRICE_SLIPPAGE=0.03
